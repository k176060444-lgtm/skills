{
  "mcpServers": {
    "MiniMax": {
      "command": "uvx",
      "args": ["minimax-mcp"],
      "env": {
        "MINIMAX_API_KEY": "'$MINIMAX_API_KEY'",
        "MINIMAX_API_HOST": "https://api.minimaxi.com",
        "MINIMAX_MCP_BASE_PATH": "/root/.openclaw/workspace/minimax-output",
        "MINIMAX_API_RESOURCE_MODE": "local"
      }
    }
  }
}
